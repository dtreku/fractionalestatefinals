{
  "name": "fractionalestate-blockchain",
  "version": "1.0.0",
  "description": "FractionalEstate - PropTech Real Estate Tokenization Smart Contracts",
  "main": "truffle-config.js",
  "scripts": {
    "compile": "truffle compile",
    "migrate": "truffle migrate",
    "migrate:sepolia": "truffle migrate --network sepolia",
    "test": "truffle test",
    "test:coverage": "truffle run coverage",
    "verify:sepolia": "truffle run verify FractionalEstate PropertyGovernance --network sepolia",
    "console": "truffle console",
    "console:sepolia": "truffle console --network sepolia",
    "flatten": "truffle-flattener contracts/FractionalEstate.sol > flattened/FractionalEstate_flat.sol"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@truffle/hdwallet-provider": "^2.1.15",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@openzeppelin/test-helpers": "^0.5.16",
    "chai": "^4.3.7",
    "truffle": "^5.11.5",
    "truffle-plugin-verify": "^0.6.7",
    "solidity-coverage": "^0.8.5"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "real-estate",
    "tokenization",
    "erc1155",
    "proptech"
  ],
  "author": "MIS2502/MIS510 Student",
  "license": "MIT"
}
