# ==================================================
# FractionalEstate - Environment Configuration
# ==================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ==================================================
# WALLET CONFIGURATION
# ==================================================
# Your MetaMask wallet mnemonic (12 or 24 words)
# Get this from MetaMask: Settings > Security & Privacy > Reveal Secret Recovery Phrase
MNEMONIC="your twelve word mnemonic phrase goes here replace with actual words"

# ==================================================
# RPC PROVIDER API KEYS
# ==================================================
# Infura API Key (https://infura.io)
# 1. Create account at infura.io
# 2. Create new project
# 3. Copy Project ID
INFURA_API_KEY="your_infura_api_key_here"

# Alchemy API Key (https://alchemy.com) - Alternative to Infura
# 1. Create account at alchemy.com
# 2. Create new app (select Sepolia)
# 3. Copy API Key
ALCHEMY_API_KEY="your_alchemy_api_key_here"

# ==================================================
# BLOCK EXPLORER API KEYS
# ==================================================
# Etherscan API Key (https://etherscan.io)
# 1. Create account at etherscan.io
# 2. Go to API-Keys section
# 3. Create new API Key
ETHERSCAN_API_KEY="your_etherscan_api_key_here"

# ==================================================
# DEPLOYMENT CONFIGURATION
# ==================================================
# Treasury address for platform fees (defaults to deployer)
TREASURY_ADDRESS=""

# Minimum investment in wei (0.001 ETH = 1000000000000000 wei)
MINIMUM_INVESTMENT="1000000000000000"

# ==================================================
# IPFS CONFIGURATION (Optional)
# ==================================================
# Pinata API Keys (https://pinata.cloud)
PINATA_API_KEY=""
PINATA_SECRET_KEY=""

# ==================================================
# FRONTEND CONFIGURATION (for reference)
# ==================================================
# These values will be used in the frontend .env
# NEXT_PUBLIC_FRACTIONALESTATE_ADDRESS=""
# NEXT_PUBLIC_GOVERNANCE_ADDRESS=""
# NEXT_PUBLIC_CHAIN_ID="11155111"
