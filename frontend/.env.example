# ==============================================
# FractionalEstate Frontend Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values

# --------------------------
# Supabase Configuration
# --------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------
# Blockchain Configuration
# --------------------------
# Network: sepolia, mainnet, localhost
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_NETWORK_NAME=sepolia

# RPC URLs
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/your-infura-key
# Alternative: Alchemy
# NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key

# WalletConnect Project ID (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --------------------------
# Contract Addresses
# --------------------------
# These are populated after deployment
NEXT_PUBLIC_PROPERTY_FACTORY_ADDRESS=
NEXT_PUBLIC_INVESTOR_REGISTRY_ADDRESS=
NEXT_PUBLIC_DIVIDEND_DISTRIBUTOR_ADDRESS=
NEXT_PUBLIC_PROPERTY_GOVERNANCE_ADDRESS=

# Sample Property (for testing)
NEXT_PUBLIC_SAMPLE_PROPERTY_TOKEN_ADDRESS=

# Stablecoin Addresses (Sepolia)
NEXT_PUBLIC_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
NEXT_PUBLIC_USDT_ADDRESS=0xaA8E23Fb1079EA71e0a56F48a2aA51851D8433D0

# --------------------------
# Application Settings
# --------------------------
NEXT_PUBLIC_APP_NAME=FractionalEstate
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Minimum investment amount in USD
NEXT_PUBLIC_MIN_INVESTMENT=100

# --------------------------
# API Keys (Server-side only)
# --------------------------
# Etherscan API Key (for verification and data)
ETHERSCAN_API_KEY=your-etherscan-key

# CoinGecko API (for price feeds)
COINGECKO_API_KEY=your-coingecko-key

# --------------------------
# Feature Flags
# --------------------------
NEXT_PUBLIC_ENABLE_TESTNET_MODE=true
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
